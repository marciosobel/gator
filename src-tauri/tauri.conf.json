{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "croc-ui",
  "version": "0.1.0",
  "identifier": "dev.marciosobel.croc-ui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Croc UI",
        "label": "tray",
        "url": "tray",
        "width": 280,
        "height": 354,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "closable": false,
        "resizable": false
      },
      {
        "title": "Croc UI",
        "label": "main",
        "url": "main",
        "width": 600,
        "height": 400,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
